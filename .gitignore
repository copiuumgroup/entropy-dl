# ─── Dependencies ───
node_modules/
**/node_modules/

# ─── Build output ───
# Frontend build is regenerated by build.bat / build.sh
frontend/build/
# backend/webdist is also regenerated; only a dev placeholder index.html is kept
# in source (see backend/webdist/index.html) so `go build` works without a
# frontend build present.
backend/webdist/assets/
backend/webdist/favicon.svg

# ─── Compiled binaries & release artifacts ───
*.exe
*.exe~
*.dll
*.so
*.dylib
entropy
entropy.exe
releases/

# ─── Runtime data (SQLite DBs & backups) ───
*.db
*.db.bak
*.sqlite
*.sqlite3

# ─── Logs & OS junk ───
*.log
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ───
.vscode/
.idea/
*.swp
*.swo

# ─── Environment / secrets ───
.env
.env.*
!.env.example
